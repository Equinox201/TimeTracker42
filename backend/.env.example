APP_ENV=local
APP_BASE_URL=http://127.0.0.1:8000
API_HOST=127.0.0.1
API_PORT=8000
API_PREFIX=/api/v1

DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/timetracker42

JWT_SECRET=change_me
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=30
OAUTH_STATE_TTL_MINUTES=10
MOBILE_OTC_TTL_MINUTES=5
TOKEN_ENCRYPTION_KEY=change_me

FORTYTWO_CLIENT_ID=change_me
FORTYTWO_CLIENT_SECRET=change_me
FORTYTWO_REDIRECT_URI=http://127.0.0.1:8000/api/v1/auth/42/callback
FORTYTWO_OAUTH_AUTHORIZE_URL=https://api.intra.42.fr/oauth/authorize
FORTYTWO_OAUTH_TOKEN_URL=https://api.intra.42.fr/oauth/token
FORTYTWO_API_BASE_URL=https://api.intra.42.fr/v2

MOBILE_DEEP_LINK_SCHEME=timetracker42
SYNC_COOLDOWN_MINUTES=5
STALE_WARNING_HOURS=3
RATE_LIMIT_AUTH_START_PER_MINUTE=20
RATE_LIMIT_AUTH_EXCHANGE_PER_MINUTE=10
RATE_LIMIT_AUTH_REFRESH_PER_MINUTE=30
RATE_LIMIT_SYNC_MANUAL_PER_MINUTE=6
